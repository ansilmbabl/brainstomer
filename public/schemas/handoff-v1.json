{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brainstormer.local/schemas/handoff-v1.json",
  "title": "Brainstormer handoff v1",
  "type": "object",
  "required": ["handoffVersion", "exportedAt", "session", "scorecard", "assumptions", "messages", "openQuestions"],
  "properties": {
    "handoffVersion": { "const": "1.0" },
    "exportedAt": { "type": "string", "format": "date-time" },
    "session": {
      "type": "object",
      "required": ["id", "title", "mode", "phase", "phaseLabel", "focusRegion", "focusIndustry", "researchMode"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "mode": { "type": "string" },
        "phase": { "type": "string" },
        "phaseLabel": { "type": "string" },
        "focusRegion": { "type": ["string", "null"] },
        "focusIndustry": { "type": ["string", "null"] },
        "researchMode": { "type": "boolean" }
      }
    },
    "scorecard": {},
    "assumptions": {},
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "content", "createdAt"],
        "properties": {
          "role": { "type": "string" },
          "content": { "type": "string" },
          "createdAt": { "type": "string" }
        }
      }
    },
    "artifactMd": { "type": ["string", "null"] },
    "openQuestions": { "type": "array", "items": { "type": "string" } }
  }
}
